{
	"compilerOptions": {
		"target": "es2022",
		"module": "CommonJS",
		"outDir": "./dist",
		"rootDir": "./src",
		"types": ["node"],
		"strict": true,
		"lib": ["ES2022"],
		"esModuleInterop": true,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		"templates/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx"
	]
}
