{
	"$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/.source/*",
			"!**/.next/*",
			"app/**/*.{js,ts,jsx,tsx,css}",
			"lib/**/*.{js,ts,tsx}",
			"content/**/*.mdx",
			"*.{js,ts,tsx,json,mjs}"
		]
	},
	"formatter": { "enabled": true },
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	}
}
