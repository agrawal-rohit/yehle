{
  "name": "{{ name }}",
  "version": "0.0.0",
  "type": "module",
  {{#public}}
  "private": false,
  {{/public}}
  {{^public}}
  "private": true,
  {{/public}}
  "packageManager": "{{ packageManagerVersion }}",
  {{#public}}
  "license": "MIT",
  "homepage": "https://github.com/{{ authorGitUsername }}/{{ name }}#readme",
  "bugs": "https://github.com/{{ authorGitUsername }}/{{ name }}/issues",
  "repository": "https://github.com/{{ authorGitUsername }}/{{ name }}",
  "author": "{{ authorName }} <{{ authorGitEmail }}>",
  {{/public}}
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm exec biome lint --write",
    "format": "pnpm exec biome format --write",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm exec biome check --write",
    "check:ci": "pnpm run typecheck && pnpm exec biome check",
    "cov": "echo 'No tests configured for documentation site'",
    "prepare": "husky"
  },
  "dependencies": {
    "fumadocs-core": "^16.6.17",
    "fumadocs-mdx": "^14.2.10",
    "fumadocs-ui": "^16.6.17",
    "next": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.2"
  }
}
